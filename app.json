{
  "expo": {
    "name": "Hexli",
    "slug": "Hexli",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/ios-icon-dark.png",
    "scheme": "hexli",
    "userInterfaceStyle": "dark",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.hexli.app",
      "infoPlist": {
        "NSLocalNetworkUsageDescription": "Hexli uses the local network during development to load JavaScript from Metro on your computer.",
        "NSBonjourServices": [
          "_http._tcp"
        ]
      },
      "icon": "./assets/images/ios-icon-dark.png"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#1a1a2e",
          "dark": {
            "backgroundColor": "#1a1a2e"
          }
        }
      ],
      "expo-sharing",
      "expo-notifications"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "ba469107-e186-43cb-928a-01a504e35706"
      }
    }
  }
}
